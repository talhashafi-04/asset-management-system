<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.assetsystem.controller.AssetDisplayController">
    
    <top>
        <fx:include fx:id="topbar" source="Topbar.fxml"/>
    </top>

    <left>
        <fx:include fx:id="sidebar" source="Sidebar.fxml"/>
    </left>

    <center>
        <VBox spacing="10" style="-fx-background-color: white;">
            <padding><Insets bottom="20" left="20" right="20" top="20" /></padding>
            
            <Label fx:id="pageTitle" text="Assets" style="-fx-font-size: 24px; -fx-text-fill: #337ab7;" />
            
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Search" />
                <TextField fx:id="searchField" promptText="Category, manufacturer, model, serial, status..." prefWidth="320"/>
                <Button fx:id="btnClearSearch" text="Clear" onAction="#onClearSearch"/>
                <Region HBox.hgrow="ALWAYS" />
            </HBox>

            <TableView fx:id="assetTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colCategory" text="Category" prefWidth="120" />
                    <TableColumn fx:id="colModel" text="Model" prefWidth="120" />
                    <TableColumn fx:id="colManufacturer" text="Manufacturer" prefWidth="120" />
                    <TableColumn fx:id="colSerial" text="Product Serial No" prefWidth="160" />
                    <TableColumn fx:id="colEmployee" text="Assigned to" prefWidth="140" />
                    <TableColumn fx:id="colEmpDept" text="Dept (allocation)" prefWidth="120" />
                    <TableColumn fx:id="colAllocDate" text="Allocated on" prefWidth="110" />
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="100" />
                    <TableColumn fx:id="colAction" text="Action" prefWidth="90" />
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
