<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.assetsystem.controller.AssetLifeCycleController">

    <top>
        <fx:include fx:id="topbar" source="Topbar.fxml"/>
    </top>

    <left>
        <fx:include fx:id="sidebar" source="Sidebar.fxml"/>
    </left>

    <center>
        <VBox spacing="10" style="-fx-background-color: white;">
            <padding><Insets bottom="20" left="20" right="20" top="20"/></padding>

            <Label text="Asset life cycle" style="-fx-font-size: 24px; -fx-text-fill: #337ab7;"/>
            <Label text="Allocation history (newest first). Empty if no rows exist in Asset_Allocation." style="-fx-text-fill: #6c757d;" wrapText="true"/>

            <TableView fx:id="allocTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colAllocId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colSerial" text="Serial" prefWidth="130"/>
                    <TableColumn fx:id="colModel" text="Model" prefWidth="120"/>
                    <TableColumn fx:id="colEmployee" text="Employee" prefWidth="130"/>
                    <TableColumn fx:id="colDept" text="Department" prefWidth="100"/>
                    <TableColumn fx:id="colLocation" text="Location" prefWidth="100"/>
                    <TableColumn fx:id="colAllocStatus" text="Alloc. status" prefWidth="100"/>
                    <TableColumn fx:id="colAllocDate" text="Allocated" prefWidth="100"/>
                    <TableColumn fx:id="colReturnDate" text="Returned" prefWidth="100"/>
                    <TableColumn fx:id="colNotes" text="Notes" prefWidth="160"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
