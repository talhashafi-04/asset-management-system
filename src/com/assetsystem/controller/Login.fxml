<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.assetsystem.controller.LoginController" style="-fx-background-color: #f0f4f4;">
    <center>
        <VBox alignment="CENTER" spacing="0" maxWidth="400">
            <VBox spacing="20" style="-fx-background-color: white; -fx-padding: 36; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 12, 0, 0, 2);">
                <Label text="Sign in" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #008080;"/>
                <Label text="Use your Asset Management System account." style="-fx-text-fill: #6c757d;" wrapText="true"/>

                <GridPane hgap="8" vgap="12">
                    <columnConstraints>
                        <ColumnConstraints minWidth="90"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
                    </columnConstraints>
                    <Label text="Username" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="fieldUsername" promptText="Username" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Label text="Password" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <PasswordField fx:id="fieldPassword" promptText="Password" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                </GridPane>

                <Label text="Quick fill (temporary)" style="-fx-text-fill: #999; -fx-font-size: 11px;"/>
                <HBox spacing="8">
                    <Button text="Admin" onAction="#onFillAdmin" style="-fx-padding: 6 14;"/>
                    <Button text="Staff" onAction="#onFillStaff" style="-fx-padding: 6 14;"/>
                </HBox>

                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button fx:id="btnLogin" text="Login" defaultButton="true" onAction="#onLogin" style="-fx-background-color: #008080; -fx-text-fill: white; -fx-padding: 8 24;"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
